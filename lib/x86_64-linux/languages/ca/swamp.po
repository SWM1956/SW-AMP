#: swamp_strings.ebass_error_codec
msgctxt "swamp_strings.ebass_error_codec"
msgid ""
"The file uses a codec that is not available/supported. This can apply to WAV "
"and AIFF files."
msgstr ""
"El fitxer utilitza un còdec que no està disponible/no és compatible. Això es "
"pot aplicar als fitxers WAV i AIFF."

#: swamp_strings.ebass_error_denied
msgctxt "swamp_strings.ebass_error_denied"
msgid "A valid username/password is required."
msgstr ""

#: swamp_strings.ebass_error_fileform
msgctxt "swamp_strings.ebass_error_fileform"
msgid "The files format is not recognised/supported."
msgstr "El format dels fitxers no és reconegut/admès."

#: swamp_strings.ebass_error_fileopen
msgctxt "swamp_strings.ebass_error_fileopen"
msgid "The file could not be opened."
msgstr "No s'ha pogut obrir el fitxer."

#: swamp_strings.ebass_error_format
msgctxt "swamp_strings.ebass_error_format"
msgid "The sample format is not supported."
msgstr "El protocol a l'URL no és compatible."

#: swamp_strings.ebass_error_illparam
msgctxt "swamp_strings.ebass_error_illparam"
msgid "url is not a valid URL."
msgstr "url no és un URL vàlid."

#: swamp_strings.ebass_error_init
msgctxt "swamp_strings.ebass_error_init"
msgid "BASS_Init has not been successfully called."
msgstr "BASS_Init no s'ha cridat correctament."

#: swamp_strings.ebass_error_mem
msgctxt "swamp_strings.ebass_error_mem"
msgid "There is insufficient memory."
msgstr "No hi ha prou memòria."

#: swamp_strings.ebass_error_no3d
msgctxt "swamp_strings.ebass_error_no3d"
msgid "Could not initialize 3D support."
msgstr "No s'ha pogut inicialitzar el suport 3D."

#: swamp_strings.ebass_error_nonet
msgctxt "swamp_strings.ebass_error_nonet"
msgid ""
"No internet connection could be opened. Can be caused by a bad proxy setting."
msgstr ""
"No s'ha pogut obrir cap connexió a Internet. Pot ser causat per una "
"configuració de proxy incorrecta."

#: swamp_strings.ebass_error_notaudio
msgctxt "swamp_strings.ebass_error_notaudio"
msgid ""
"The file does not contain audio, or it also contains video and videos are "
"disabled."
msgstr ""
"El fitxer no conté àudio o també conté vídeo i els vídeos estan desactivats."

#: swamp_strings.ebass_error_notavail
msgctxt "swamp_strings.ebass_error_notavail"
msgid ""
"The BASS_STREAM_AUTOFREE flag cannot be combined with the BASS_STREAM_DECODE "
"flag."
msgstr ""
"El senyalador BASS_STREAM_AUTOFREE no es pot combinar amb el senyalador "
"BASS_STREAM_DECODE."

#: swamp_strings.ebass_error_protocol
msgctxt "swamp_strings.ebass_error_protocol"
msgid "The protocol in url is not supported."
msgstr "El protocol a l'URL no és compatible."

#: swamp_strings.ebass_error_speaker
msgctxt "swamp_strings.ebass_error_speaker"
msgid "The specified SPEAKER flags are invalid."
msgstr "Els indicadors SPEAKER especificats no són vàlids."

#: swamp_strings.ebass_error_ssl
msgctxt "swamp_strings.ebass_error_ssl"
msgid "SSL/HTTPS support is not available. See BASS_CONFIG_LIBSSL."
msgstr "El suport SSL/HTTPS no està disponible. Vegeu BASS_CONFIG_LIBSSL."

#: swamp_strings.ebass_error_timeout
msgctxt "swamp_strings.ebass_error_timeout"
msgid ""
"The server did not respond to the request within the timeout period, as set "
"with the BASS_CONFIG_NET_TIMEOUT config option."
msgstr ""
"El servidor no va respondre a la sol·licitud dins del període de temps "
"d'espera, tal com s'estableix amb l'opció de configuració "
"BASS_CONFIG_NET_TIMEOUT."

#: swamp_strings.ebass_error_unknown
msgctxt "swamp_strings.ebass_error_unknown"
msgid "Some other mystery problem!"
msgstr "Un altre problema de misteri!"

#: swamp_strings.ebass_error_unstreamable
msgctxt "swamp_strings.ebass_error_unstreamable"
msgid ""
"The file cannot be streamed. This could be because an MP4 files mdat atom "
"comes before its \"moov\" atom."
msgstr ""
"No es pot reproduir el fitxer. Això podria ser perquè un àtom mdat de "
"fitxers MP4 arriba abans del seu àtom \"moov\"."

